{
  "name": "skillctrl",
  "version": "1.4.0",
  "description": "CLI to manage and deploy AI agent skills",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/alexjcm/skillctrl#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexjcm/skillctrl.git"
  },
  "bugs": {
    "url": "https://github.com/alexjcm/skillctrl/issues"
  },
  "bin": {
    "skillctrl": "dist/index.js"
  },
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE*"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --target node22 --clean --minify --dts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "cli",
    "agent-skills",
    "developer-tools",
    "codex",
    "claude-code",
    "cursor"
  ],
  "dependencies": {
    "@clack/prompts": "~1.3.0",
    "commander": "14.0.3",
    "fast-glob": "3.3.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.5"
  }
}
