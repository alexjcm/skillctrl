{
  "name": "@agent-skillset/cli",
  "version": "1.0.0",
  "description": "CLI to manage and deploy AI agent skills",
  "type": "module",
  "bin": {
    "skills": "./bin/skills"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "lint": "bun run --bun tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "1.1.0",
    "commander": "14.0.3",
    "fast-glob": "3.3.3",
    "fs-extra": "11.3.4",
    "log-symbols": "7.0.1",
    "picocolors": "1.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0"
  }
}
