{
  "name": "skillctrl",
  "version": "1.0.0",
  "description": "CLI to manage and deploy AI agent skills",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/alexjcm/skillctrl#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexjcm/skillctrl.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/alexjcm/skillctrl/issues"
  },
  "bin": {
    "skillctrl": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE*"
  ],
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun --watch run src/index.ts",
    "build": "tsup src/index.ts --format esm --target node20 --clean --minify",
    "lint": "bun run --bun tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "cp ../README.md .",
    "postpack": "rm -f README.md",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": [
    "ai",
    "agents",
    "skills",
    "cli",
    "agent-skills",
    "developer-tools",
    "codex",
    "claude-code",
    "cursor",
    "windsurf"
  ],
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "commander": "14.0.3",
    "fast-glob": "3.3.3",
    "fs-extra": "11.3.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.0",
    "vitest": "^4.1.0"
  }
}
